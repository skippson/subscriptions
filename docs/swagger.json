            "properties": {
                "end_date": {
                    "description": "Дата окончания подписки в формате год-месяц",
                    "type": "string"
                },
                "name": {
                    "description": "Название подписки",
                    "type": "string"
                },
                "price": {
                    "description": "Цена за подписку в месяц",
                    "type": "integer",
                    "minimum": 0
