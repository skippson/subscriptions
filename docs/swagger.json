                },
                "id": {
                    "description": "ID подписки в формате UUID",
                    "type": "string"
                },
                "name": {
                    "description": "Название подписки",
                    "type": "string"
                },
                "price": {
                    "description": "Цена за подписку в месяц",
                    "type": "integer"
                },
                "start_date": {
                    "description": "Дата начала подписки в формате год-месяц",
                    "type": "string"
                },
                "user_id": {
                    "description": "ID пользователя в формате UUID",
